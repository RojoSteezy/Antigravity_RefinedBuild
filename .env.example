# ANPDP Compliance Co-pilot - Configuration
# Copy this file to .env and fill in at least one API key.

# AI Provider Keys (at least one is required for agentic features)
# --------------------------------------------------------------

# Anthropic (Claude 3.5 Sonnet) - Priority 1
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google Gemini (Gemini 1.5 Flash) - Priority 2
GOOGLE_API_KEY=your_gemini_key_here

# OpenAI (ChatGPT - gpt-4o) - Priority 3
OPENAI_API_KEY=your_openai_key_here

# App Configuration
# -----------------
FLASK_DEBUG=true
PORT=5000
# PASSWORD=scrypt:... (Optional: set to override default admin password)
